{
  "name": "python-import-size",
  "displayName": "Python Import Size",
  "description": "Display Python import library sizes inline in VSCode",
  "publisher": "qiufeng-vscext",
  "icon": "icon.png",
  "version": "1.0.3",
  "engines": {
    "vscode": "^1.116.0"
  },
  "keywords": [
    "python",
    "import",
    "size",
    "visualization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/qiufengcute/python-import-size.git"
  },
  "author": "Qiufeng",
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Python Import Size",
      "properties": {
        "python-import-size.cacheTTL": {
          "type": "number",
          "default": 5,
          "description": "Cache TTL in mins (0 means no cache)"
        },
        "python-import-size.mode": {
          "type": "string",
          "default": "package",
          "description": "Get size mode",
          "enum": [
            "package",
            "module"
          ]
        }
      }
    },
    "commands": [
      {
        "command": "python-import-size.clearCache",
        "title": "Clear Python Import Size Cache",
        "category": "Python Import Size"
      },
      {
        "command": "python-import-size.refresh",
        "title": "Refresh import size",
        "category": "Python Import Size"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "python-import-size.clearCache"
        },
        {
          "command": "python-import-size.refresh"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
